# ---- Server ----
PORT=4242
# Public base URL of THIS server (used to build share links + QR codes).
# In production set to your real domain, e.g. https://lovesite.in
BASE_URL=http://localhost:4242

# ---- Razorpay ----
# Get these from https://dashboard.razorpay.com/app/keys
# Leave BLANK to run in TEST_MODE (no real payment — great for local demos).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret you set in the Razorpay dashboard (Settings > Webhooks).
# Only needed once you configure the webhook. Leave blank until then.
RAZORPAY_WEBHOOK_SECRET=
