# ---- Database (Supabase Postgres) ----
# Supabase → your project → "Connect" button → "Session pooler" tab → URI.
# IMPORTANT: use the POOLER host (aws-0-<region>.pooler.supabase.com), NOT
# db.<ref>.supabase.co — the direct host is IPv6-only and often unreachable.
# Replace <ref>, <region>, and PASSWORD with your real values (note: the user
# is "postgres.<ref>", and the host/port is the SESSION pooler on 5432).
DATABASE_URL="postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Public base URL (for share links + QR codes) ----
# Local: http://localhost:3000   Prod: https://your-domain.com
BASE_URL="http://localhost:3000"

# ---- Razorpay ----
# https://dashboard.razorpay.com/app/keys — leave blank to run in TEST_MODE (no real charge).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Razorpay dashboard → Settings → Webhooks). Optional until configured.
RAZORPAY_WEBHOOK_SECRET=
